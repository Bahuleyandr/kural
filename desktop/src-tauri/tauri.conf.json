{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kural",
  "version": "0.2.0",
  "identifier": "ai.kural.tts",
  "build": {
    "frontendDist": "../../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../frontend && npx pnpm@9.15.9 dev",
    "beforeBuildCommand": "cd ../frontend && npx pnpm@9.15.9 build:desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:; media-src 'self' http://127.0.0.1:* http://localhost:* blob: data:; connect-src 'self' http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../backend/app": "backend/app",
      "../../backend/scripts": "backend/scripts",
      "../../backend/requirements.txt": "backend/requirements.txt"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
