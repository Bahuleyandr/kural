{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kural",
  "version": "0.1.0",
  "identifier": "ai.kural.app",
  "build": {
    "frontendDist": "../../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../../frontend && pnpm dev",
    "beforeBuildCommand": "cd ../../frontend && pnpm build:desktop"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {},
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
