# Backend
TTS_ENGINE=kokoro-onnx
MODEL_CACHE_DIR=~/.cache/kural/kokoro
MODEL_PACK_ROOT=~/.cache/kural
SUPERTONIC_MODEL_DIR=~/.cache/kural/supertonic
CLONE_CACHE_DIR=~/.cache/kural/clones
CLONE_MIN_DURATION_S=5
CLONE_MAX_DURATION_S=30
CLONE_MAX_UPLOAD_MB=25
CLONE_ARCHIVE_MAX_UPLOAD_MB=250

# Optional shared-secret for /api/* routes. Empty = auth disabled.
# Required if you bind the backend on anything other than 127.0.0.1.
KURAL_API_KEY=

# Per-IP rate limits, slowapi syntax (e.g. "30/minute", "5/second").
RATE_LIMIT_SYNTHESIZE=30/minute
RATE_LIMIT_CLONE=5/minute

# Append-only consent audit trail for /api/voices/clone uploads.
CONSENT_LOG_PATH=~/.cache/kural/consent.log

# docker-compose host bind. Default 127.0.0.1 keeps the API local-only.
# Set to 0.0.0.0 (and set KURAL_API_KEY) to expose on a LAN.
# KURAL_BIND=127.0.0.1

# docker-compose backend image flavour:
#   lite  (default) — Kokoro only, ~600 MB
#   clone           — Kokoro + Chatterbox, ~2 GB (PyTorch + voice cloning)
# KURAL_FLAVOUR=lite

# Vendor-neutral, opt-in error reporting. Both must be set for any outbound
# traffic — the default ships zero data anywhere.
# KURAL_TELEMETRY_OPT_IN=true
# KURAL_TELEMETRY_ENDPOINT=https://example.invalid/kural-events

# Optional local multilingual workflow adapters
LOCAL_ASR_ENGINE=auto
LOCAL_TRANSLATION_ENGINE=auto
TRANSCRIBE_MAX_UPLOAD_MB=250
FASTER_WHISPER_MODEL_DIR=~/.cache/kural/asr/faster-whisper
VOSK_MODEL_DIR=~/.cache/kural/asr/vosk
WHISPER_CPP_BINARY=
WHISPER_CPP_MODEL_FILE=
ARGOS_PACKAGES_DIR=~/.local/share/argos-translate/packages
INDICTRANS2_MODEL_DIR=~/.cache/kural/translation/indictrans2
ENABLE_NLLB=false
NLLB_MODEL_DIR=~/.cache/kural/translation/nllb

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Desktop release builds
# KURAL_UPDATER_PUBLIC_KEY=
# KURAL_UPDATE_ENDPOINT=https://github.com/Bahuleyandr/kural/releases/latest/download/latest.json
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
# Optional Windows Authenticode signing (the unsigned public beta works without it).
# KURAL_WIN_CERT_THUMBPRINT=
# Bundled relocatable Python runtime (python-build-standalone) version pin.
# KURAL_PYTHON_VERSION=3.12.8
# KURAL_PBS_RELEASE=20241219

# Model-download hardening (backend + desktop first run). urllib read timeout,
# plus optional pinned Kokoro digests. Set KURAL_REQUIRE_MODEL_CHECKSUM=1 to
# refuse any unpinned model download.
# KURAL_DOWNLOAD_TIMEOUT_S=300
# KURAL_KOKORO_MODEL_SHA256=
# KURAL_KOKORO_VOICES_SHA256=
# KURAL_REQUIRE_MODEL_CHECKSUM=
